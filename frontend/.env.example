# ── Mode mock (MSW) ───────────────────────────────────────────────────────────
# Mettre à true pour intercepter les appels API avec des données simulées (sans backend)
VITE_MOCK=false

# ── URL du backend (dev uniquement) ──────────────────────────────────────────
# Utilisée par le proxy Vite pour rediriger /api → backend local.
# Par défaut : http://localhost:9649 (valeur hardcodée dans vite.config.js)
# Décommenter et adapter si le backend tourne sur un autre port ou host.
# VITE_BACKEND_URL=http://localhost:9649
